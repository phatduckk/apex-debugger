{
  "manifest_version": 3,
  "name": "Apex Debugger",
  "version": "1.1",
  "description": "Debug overlay for Neptune Apex Fusion output configuration",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}

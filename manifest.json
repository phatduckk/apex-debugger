{
  "manifest_version": 3,
  "name": "Apex Debugger",
  "version": "1.1",
  "description": "Adds a bunch of useful features to Neptune's Apex Fusion",
  "browser_specific_settings": {
    "gecko": {
      "id": "apex-debugger@local",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "web_accessible_resources": [
    {
      "resources": ["img/beef.svg"],
      "matches": ["*://*/*"]
    }
  ]
}
